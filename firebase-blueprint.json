{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document with public metadata",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A single chat thread session",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "messages": { "type": "array" }
      },
      "required": ["title", "timestamp", "messages"]
    },
    "ScheduledTask": {
      "title": "ScheduledTask",
      "description": "A scheduled automation task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "prompt": { "type": "string" },
        "scheduleType": { "type": "string" },
        "time": { "type": "string" },
        "date": { "type": "string" },
        "daysOfWeek": { "type": "array" },
        "dayOfMonth": { "type": "number" },
        "expirationDate": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastRunAt": { "type": "string", "format": "date-time" },
        "nextRunAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "prompt", "scheduleType", "time", "isActive", "createdAt", "nextRunAt"]
    },
    "TaskExecution": {
      "title": "TaskExecution",
      "description": "An execution log of a scheduled task",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "taskTitle": { "type": "string" },
        "executedAt": { "type": "string", "format": "date-time" },
        "sessionId": { "type": "string" },
        "status": { "type": "string" },
        "error": { "type": "string" }
      },
      "required": ["taskId", "taskTitle", "executedAt", "sessionId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat sessions for a specific user"
    },
    "/users/{userId}/scheduledTasks/{taskId}": {
      "schema": "ScheduledTask",
      "description": "Scheduled automation tasks for a specific user"
    },
    "/users/{userId}/taskExecutions/{executionId}": {
      "schema": "TaskExecution",
      "description": "Execution log history for a specific user"
    }
  }
}
