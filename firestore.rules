rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '1VDx7iiiSQP0vWZLQgPDQxm10og1' || 
        ('email' in request.auth.token && request.auth.token.email == 'wsmathenas@gmail.com')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidChatSession(data) {
      return data.title is string 
        && data.title.size() <= 500
        && data.category is string
        && data.category.size() <= 100
        && data.messages is list
        && data.messages.size() <= 1000;
    }

    match /writer_documents/{docId} {
      allow list: if isSignedIn();
      allow get, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }

    match /evaluations/{evalId} {
      allow create, update: if isSignedIn();
      allow read, delete: if isSignedIn();
    }

    match /users/{userId} {
      allow list: if isSignedIn();
      allow get, write: if isSignedIn();

      match /sessions/{sessionId} {
        allow get, delete: if isSignedIn() && isValidId(sessionId);
        allow list: if isSignedIn();
        
        allow create: if isOwner(userId) 
          && isValidId(sessionId)
          && isValidChatSession(incoming());
          
        allow update: if isOwner(userId)
          && isValidId(sessionId)
          && isValidChatSession(incoming());
      }
      
      match /drafts/{draftId} {
        allow get: if isSignedIn() && isValidId(draftId);
        allow list: if isSignedIn();
        allow write: if isOwner(userId) && isValidId(draftId);
      }

      match /skills/{skillId} {
        allow get, delete: if isSignedIn() && isValidId(skillId);
        allow list: if isSignedIn();
        allow write: if isOwner(userId) && isValidId(skillId);
      }

      match /scheduledTasks/{taskId} {
        allow list: if isOwner(userId);
        allow get, delete: if isOwner(userId) && isValidId(taskId);
        allow write: if isOwner(userId) && isValidId(taskId);
      }

      match /taskExecutions/{executionId} {
        allow list: if isOwner(userId);
        allow get, delete: if isOwner(userId) && isValidId(executionId);
        allow write: if isOwner(userId) && isValidId(executionId);
      }
    }

    // Support collection group queries for analytics & dashboards
    match /{path=**}/sessions/{sessionId} {
      allow list, read: if isSignedIn();
    }
    match /{path=**}/drafts/{draftId} {
      allow list, read: if isSignedIn();
    }
  }
}
